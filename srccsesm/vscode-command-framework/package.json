{
	"name": "@vs/vscode-command-framework",
	"version": "0.0.0-placeholder",
	"description": "Commands framework for VSCode extensions",
	"main": "dist/src/api.d.ts",
	"imports": {
		"#vscode-abstractions/logFile.js": "./dist/src/abstractions/node/logFile.js"
	},
	"scripts": {
